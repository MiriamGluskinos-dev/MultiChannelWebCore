{
  "name": "@igds/icons",
  "version": "0.1.42",
  "description": "IGDS Icons",
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "svg-to-ts": "12.0.0"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "import": "./lib/*.js"
    }
  },
  "types": "./lib/index.d.ts",
  "publishConfig": {
    "@igds:registry": "https://gitlab.com/api/v4/projects/60048869/packages/npm/"
  },
  "files": [
    "README.md",
    "lib/**",
    "package.json"
  ],
  "scripts": {
    "build": "svg-to-ts-object --config ./.svg-to-tsrc && node ./scripts/split-generated-icons.mjs"
  }
}